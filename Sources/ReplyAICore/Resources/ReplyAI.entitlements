<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Sandbox is OFF: reading ~/Library/Messages/chat.db requires Full
	     Disk Access, which is granted to non-sandboxed bundles only.
	     (Sandboxed apps can never be added to the FDA TCC list.) -->
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
